# rusty-SUNDIALS v10 — GPU Inference Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# =============================================================================
# PRIVATE GPU INFERENCE (Highest Priority — Zero API Cost)
# =============================================================================
# Set this to your Vertex AI or Cloud Run GPU endpoint URL.
# When set, ALL LLM calls (peer review, physics validation, code synthesis,
# Lean 4 tactics) are routed to your private on-GPU Qwen3-8B + Coder-7B stack.
#
# Vertex AI endpoint:
# VLLM_INFERENCE_URL=https://europe-west1-aiplatform.googleapis.com/v1/projects/mopga-487511/locations/europe-west1/endpoints/<ENDPOINT_ID>:predict
#
# Cloud Run GPU endpoint:
# VLLM_INFERENCE_URL=https://rusty-sundials-v10-gpu-xxxxx-ew.a.run.app
#
VLLM_INFERENCE_URL=

# GPU type on the inference server ("L4" | "A100")
GPU_TYPE=A100

# vLLM quantization (empty=fp16 for A100, fp8 for L4)
VLLM_QUANT=

# Qwen3-8B thinking budget (tokens)
QWEN3_THINKING_BUDGET=8192

# =============================================================================
# HUGGINGFACE (for model download during Docker build)
# =============================================================================
HF_TOKEN=hf_...

# =============================================================================
# FALLBACK API KEYS (used when VLLM_INFERENCE_URL is not set)
# =============================================================================

# Google Gemini (DeepThink fallback)
GEMINI_API_KEY=AIza...

# Mistral (peer review fallback)
MISTRAL_API_KEY=...

# Gwen via HuggingFace Inference API (peer review fallback)
HUGGINGFACE_API_TOKEN=hf_...

# Local vLLM endpoint for Gwen (if running locally)
# GWEN_API_URL=http://localhost:8001

# =============================================================================
# GCP CONFIGURATION
# =============================================================================
PROJECT_ID=mopga-487511
REGION=europe-west1
VERTEX_AI_REGION=europe-west1
GOOGLE_CLOUD_PROJECT=mopga-487511

# =============================================================================
# LEAN 4 PROOF CACHE (Redis)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# BUDGET & MONITORING
# =============================================================================
BUDGET_USD=100
BUDGET_ALERT_AT=50
BUDGET_KILL_AT=95

# =============================================================================
# SLURM (CEA/ITER exascale — optional)
# =============================================================================
# SLURM_PARTITION=gpu_a100
