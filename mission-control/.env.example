# Mission Control Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or .env to git.

# Google OAuth 2.0 Client ID (from GCP Console → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Admin email address (controls who gets 'admin' role in Mission Control)
VITE_ADMIN_EMAIL=your-email@gmail.com

# GCP Project ID (used for Cloud Run API base URL if needed)
VITE_GCP_PROJECT_ID=your-gcp-project-id

# API base URL for the serverless backend (leave empty for mock mode)
VITE_API_URL=
